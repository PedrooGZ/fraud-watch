APP_ENV=production
MODEL_PATH=artifacts/fraud_model.joblib
MODEL_METADATA_PATH=artifacts/fraud_model_metadata.json
REVIEW_POLICY_PATH=review_policy.json
PREDICTIONS_LOG_PATH=logs/predictions.jsonl
DATABASE_URL=postgresql+psycopg2://<usuario>:<password>@<tu-servidor>.postgres.database.azure.com:5432/fraud_watch?sslmode=require
CORS_ALLOW_ORIGINS=https://<tu-dominio>
ROOT_PATH=
JWT_SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
